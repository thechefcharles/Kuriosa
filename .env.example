# Supabase
# Project URL from Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
# Anon (public) key from Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Service role key — server-only; required for content persistence (Phase 4.9). Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=

# Internal editorial workflow allowlist (Phase 4.10).
# Example: dev1@example.com,dev2@example.com
INTERNAL_CONTENT_WORKFLOW_ALLOWLIST_EMAILS=

# OpenAI
# API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# PostHog (analytics — safe for client)
# Project API key from PostHog Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_api_key_here
# Host: https://us.i.posthog.com or https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry (error monitoring)
# Client DSN — safe for client, from Sentry Project Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
# Server DSN — optional, defaults to NEXT_PUBLIC_SENTRY_DSN if unset
SENTRY_DSN=
# Optional: for source map uploads (Sentry Project Settings → Client Keys)
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_AUTH_TOKEN=sntrys_...
